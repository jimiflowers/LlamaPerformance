{
  "name": "llamaperformance",
  "version": "1.0.0",
  "description": "Benchmark multiple GGUF models served by llama.cpp or llama-swap",
  "main": "src/server/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node src/server/index.js",
    "client": "cd src/client && npm run dev",
    "build": "cd src/client && npm run build",
    "start": "npm run build && npm run server",
    "setup": "npm install && cd src/client && npm install"
  },
  "keywords": [
    "llm",
    "benchmark",
    "llama.cpp",
    "gguf",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "overrides": {
    "node-domexception": "npm:domexception@latest"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "openai": "^4.104.0",
    "ssh2": "^1.17.0",
    "systeminformation": "^5.21.20",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^9.6.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}

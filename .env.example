# LlamaPerformance Environment Configuration
# Copy this file to .env and fill in your values.
# Most settings are now managed via the Settings UI and stored in settings.json.

# Backend port (default 3001). Change requires server restart.
PORT=3001

# Vite build-time variable — required, do not move to settings.json
VITE_API_URL=/api

# Optional: pre-seed settings.json defaults (overridden by the Settings UI once saved)
# LLAMA_API_URL=http://your-gpu-server:8000
# LOG_LEVEL=info
# MODELS_DIR=/path/to/gguf/files
